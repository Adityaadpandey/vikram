{
	"compilerOptions": {
	  "target": "ESNext",
	  "module": "NodeNext",
	  "moduleResolution": "NodeNext",
	  "declaration": true,
	  "outDir": "./dist",
	  "strict": true,
	  "esModuleInterop": true,
	  "allowSyntheticDefaultImports": true,
	  "skipLibCheck": true,
	  "forceConsistentCasingInFileNames": true,
	  "types": ["node"]
	},
	"include": ["./client.ts", "./seed.ts", "./prisma/**/*"],
	"exclude": ["node_modules", "dist", "generated"]
  }
